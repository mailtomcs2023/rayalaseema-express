generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USER & AUTH ============

enum Role {
  ADMIN           // Full access - everything
  CHIEF_SUB_EDITOR // Edit all categories, publish, breaking news
  SUB_EDITOR      // Edit assigned categories, review articles, can't publish
  REPORTER        // Write articles, upload photos, submit for review only
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          Role      @default(REPORTER)
  avatar        String?
  bio           String?
  phone         String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Category assignments (for SUB_EDITOR role)
  assignedCategories UserCategory[]

  // Articles authored
  articles      Article[]
  media         Media[]

  // Articles reviewed/edited by this user
  reviewedArticles ArticleReview[]

  @@map("users")
}

// ============ USER CATEGORY ASSIGNMENTS ============

model UserCategory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@index([userId])
  @@map("user_categories")
}

// ============ ARTICLE REVIEW LOG ============

model ArticleReview {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // "submitted", "reviewed", "approved", "rejected", "published", "edited"
  note      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([articleId])
  @@index([userId])
  @@map("article_reviews")
}

// ============ CONTENT ============

enum ArticleStatus {
  DRAFT        // Reporter working on it
  SUBMITTED    // Reporter submitted for review
  IN_REVIEW    // Sub-editor is reviewing
  APPROVED     // Chief sub-editor approved, ready to publish
  PUBLISHED    // Live on website
  REJECTED     // Sent back to reporter with notes
  ARCHIVED     // Removed from site
}

enum Language {
  TELUGU
  ENGLISH
}

model Article {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  summary         String?       @db.Text // Short 60-word summary for app
  body            String        @db.Text
  featuredImage   String?
  imageCaption    String?
  language        Language      @default(TELUGU)
  status          ArticleStatus @default(DRAFT)
  featured        Boolean       @default(false)
  breaking        Boolean       @default(false)

  // SEO
  metaTitle       String?
  metaDescription String?
  ogImage         String?

  // Scheduling
  publishedAt     DateTime?
  scheduledAt     DateTime?

  // Relations
  authorId        String
  author          User          @relation(fields: [authorId], references: [id])
  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id])
  tags            ArticleTag[]
  socialPosts     SocialPost[]
  comments        Comment[]

  // Location tagging
  constituencyId  String?
  constituency    Constituency? @relation("ArticleConstituency", fields: [constituencyId], references: [id])
  mandalId        String?
  mandal          Mandal?       @relation("ArticleMandal", fields: [mandalId], references: [id])

  // Analytics
  viewCount       Int           @default(0)

  // Editorial workflow
  rejectionNote   String?       @db.Text  // Feedback when rejected
  reviewedById    String?                 // Who reviewed this article
  reviewedAt      DateTime?               // When it was reviewed
  approvedById    String?                 // Who approved for publish
  approvedAt      DateTime?               // When approved
  reviews         ArticleReview[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([authorId])
  @@index([constituencyId])
  @@index([slug])
  @@map("articles")
}

model Category {
  id          String     @id @default(cuid())
  name        String
  nameEn      String?    // English name
  slug        String     @unique
  description String?
  color       String?    @default("#DC2626")
  sortOrder   Int        @default(0)
  active      Boolean    @default(true)

  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")

  articles    Article[]
  videos      Video[]
  assignedUsers UserCategory[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("categories")
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  articles  ArticleTag[]

  @@map("tags")
}

model ArticleTag {
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

// ============ MEDIA ============

enum MediaType {
  IMAGE
  VIDEO
  PDF
  DOCUMENT
}

model Media {
  id          String    @id @default(cuid())
  url         String
  filename    String
  altText     String?
  type        MediaType @default(IMAGE)
  size        Int       // bytes
  width       Int?
  height      Int?
  uploadedById String
  uploadedBy  User      @relation(fields: [uploadedById], references: [id])
  createdAt   DateTime  @default(now())

  @@map("media")
}

// ============ ePAPER ============

model EpaperEdition {
  id          String   @id @default(cuid())
  date        DateTime @unique @db.Date
  title       String?
  section     String   @default("main") // main, supplement, district
  pdfUrl      String
  thumbnailUrl String?
  pageCount   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@map("epaper_editions")
}

// ============ BREAKING NEWS ============

model BreakingNews {
  id          String   @id @default(cuid())
  headline    String
  headlineEn  String?
  url         String?  // optional link to article
  priority    Int      @default(0)
  active      Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("breaking_news")
}

// ============ SOCIAL MEDIA ============

enum SocialPlatform {
  FACEBOOK
  TWITTER
  INSTAGRAM
  WHATSAPP
  TELEGRAM
  YOUTUBE
}

enum SocialPostStatus {
  QUEUED
  POSTED
  FAILED
}

model SocialPost {
  id          String           @id @default(cuid())
  articleId   String
  article     Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  platform    SocialPlatform
  status      SocialPostStatus @default(QUEUED)
  postUrl     String?
  error       String?
  postedAt    DateTime?
  createdAt   DateTime         @default(now())

  @@unique([articleId, platform])
  @@map("social_posts")
}

// ============ SITE CONFIG ============

model SiteConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt

  @@map("site_config")
}

// ============ LOCATIONS (Districts → Constituencies → Mandals) ============

model District {
  id              String          @id @default(cuid())
  name            String          // Telugu name
  nameEn          String          // English name
  slug            String          @unique
  loksabhaSeats   String?         // Comma-separated Lok Sabha constituency names
  sortOrder       Int             @default(0)
  active          Boolean         @default(true)
  constituencies  Constituency[]
  createdAt       DateTime        @default(now())

  @@map("districts")
}

model Constituency {
  id          String   @id @default(cuid())
  name        String   // Telugu name
  nameEn      String   // English name
  slug        String   @unique
  type        String   @default("ASSEMBLY") // ASSEMBLY or LOKSABHA
  districtId  String
  district    District @relation(fields: [districtId], references: [id])
  loksabha    String?  // Which Lok Sabha seat this falls under
  mandals     Mandal[]
  articles    Article[] @relation("ArticleConstituency")
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([districtId])
  @@map("constituencies")
}

model Mandal {
  id              String       @id @default(cuid())
  name            String       // Telugu name
  nameEn          String       // English name
  slug            String       @unique
  constituencyId  String
  constituency    Constituency @relation(fields: [constituencyId], references: [id])
  articles        Article[]    @relation("ArticleMandal")
  sortOrder       Int          @default(0)
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())

  @@index([constituencyId])
  @@map("mandals")
}

// ============ VIDEOS ============

model Video {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?  @db.Text
  thumbnailUrl String
  videoUrl    String?  // YouTube/external URL
  duration    String?  // "12:45"
  views       Int      @default(0)
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, featured])
  @@map("videos")
}

// ============ PHOTO GALLERY ============

model PhotoGallery {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  description String?
  coverImage  String
  active      Boolean       @default(true)
  photos      GalleryPhoto[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("photo_galleries")
}

model GalleryPhoto {
  id          String       @id @default(cuid())
  galleryId   String
  gallery     PhotoGallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  imageUrl    String
  caption     String?
  sortOrder   Int          @default(0)

  @@map("gallery_photos")
}

// ============ WEB STORIES ============

model WebStory {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  imageUrl    String
  category    String?  // devotional, travel, food, history, etc.
  active      Boolean  @default(true)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("web_stories")
}

// ============ REELS ============

model Reel {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  thumbnailUrl String
  videoUrl    String?
  views       String   @default("0") // "2.5L", "95K" etc.
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("reels")
}

// ============ CARTOON (YETTETA) ============

model Cartoon {
  id          String   @id @default(cuid())
  title       String
  caption     String
  imageUrl    String
  date        DateTime @db.Date
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([date])
  @@map("cartoons")
}

// ============ ADS ============

enum AdPosition {
  HEADER_LEFT
  HEADER_RIGHT
  BANNER_MID
  SIDEBAR_SQUARE
  SIDEBAR_TALL
  LEADERBOARD
  IN_FEED
  VERTICAL_STRIP
}

model Ad {
  id          String     @id @default(cuid())
  name        String
  position    AdPosition
  imageUrl    String?
  linkUrl     String?
  htmlContent String?    @db.Text // custom HTML ad
  bgColor     String?
  textColor   String?
  active      Boolean    @default(true)
  startDate   DateTime?
  endDate     DateTime?
  clicks      Int        @default(0)
  impressions Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([position, active])
  @@map("ads")
}

// ============ COMMENTS ============

model Comment {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  content   String   @db.Text
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([articleId, approved])
  @@map("comments")
}

// ============ MANDI PRICES ============

model MandiPrice {
  id        String   @id @default(cuid())
  commodity String   // e.g. "మిర్చి", "పత్తి"
  commodityEn String // e.g. "Chilli", "Cotton"
  market    String   // e.g. "కర్నూలు"
  marketEn  String   // e.g. "Kurnool"
  price     Float    // price per quintal in Rs
  unit      String   @default("క్వింటల్")
  change    Float    @default(0) // daily change percentage
  date      DateTime @default(now())
  active    Boolean  @default(true)

  @@index([date, active])
  @@map("mandi_prices")
}

// ============ POLLS ============

model Poll {
  id        String       @id @default(cuid())
  question  String
  active    Boolean      @default(true)
  options   PollOption[]
  createdAt DateTime     @default(now())
  expiresAt DateTime?

  @@map("polls")
}

model PollOption {
  id     String @id @default(cuid())
  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text   String
  votes  Int    @default(0)

  @@index([pollId])
  @@map("poll_options")
}
